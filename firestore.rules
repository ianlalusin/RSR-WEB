rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // -------- Helpers --------
    function signedIn() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return signedIn() && request.auth.token.platformAdmin == true;
    }

    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isActiveUser() {
      return signedIn() && (me().isActive == true);
    }

    function isOIC() {
      return isActiveUser() && me().roleId == 'oic';
    }

    function isAdminOrOIC() {
      return isPlatformAdmin() || isOIC();
    }

    // District-only scope: user.access.districtIds
    function hasDistrict(districtId) {
      return isPlatformAdmin() || (isActiveUser() && (districtId in me().access.districtIds));
    }

    // -------- SocMed role helpers --------
    function socmedRole() {
      return 'socmedRole' in me() ? me().socmedRole : null;
    }

    function hasSocmedRole() {
      return isActiveUser() && socmedRole() != null;
    }

    // Admin / Manager / Validator share validation + rollout-config power
    function isSocmedStaff() {
      return isActiveUser() && socmedRole() in ['Admin', 'Manager', 'Validator'];
    }

    function isSocmedChecker() {
      return isActiveUser() && socmedRole() == 'Checker';
    }

    // -------- PLATFORM ADMIN: FULL BYPASS --------
    match /{docPath=**} {
      allow read, write: if isPlatformAdmin();
    }

    // -------- Lists (read-only for active users; all writes via Admin SDK) --------
    match /lists/{listId} {
      allow read: if isActiveUser();
      allow write: if false;
    }

    // -------- Users --------
    match /users/{uid} {
      // Read own profile
      allow read: if signedIn() && request.auth.uid == uid;

      // OIC and platform admin can read all profiles (for admin page real-time subscriptions)
      allow read: if isAdminOrOIC();

      // SocMed staff (Admin/Manager/Validator) can read all profiles for the SocMed module:
      // user lists, agent rosters, submitter names, group membership.
      allow read: if isSocmedStaff();

      // SocMed Checker can read all profiles to display agent names on submission cards.
      allow read: if isSocmedChecker();

      // Self-provision on first sign-in: user creates their own doc with safe defaults only.
      // No roleId, no socmedRole, no access overrides — admin assigns these later via Admin SDK.
      allow create: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.isActive == false
        && !('roleId' in request.resource.data)
        && !('socmedRole' in request.resource.data)
        && !('access' in request.resource.data)
        && request.resource.data.uid == uid;

      // Users can self-update display name and photo only
      allow update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt']);

      // No client-side deletes
      allow delete: if false;
    }

    // -------- Barangays --------
    match /barangays/{brgyId} {
      allow read: if isActiveUser();
      allow write: if false; // All writes via Admin SDK server actions
    }

    match /barangays/{brgyId}/{subcollection=**} {
      allow read: if isActiveUser();
      allow write: if false;
    }

    // -------- Org metadata (deprecated collections — locked) --------
    match /departments/{deptId} {
      allow read, write: if false;
    }
    match /positions/{posId} {
      allow read, write: if false;
    }
    match /org/departments/{deptId} {
      allow read, write: if false;
    }
    match /org/positions/{posId} {
      allow read, write: if false;
    }

    // -------- Field data (district-scoped) --------
    match /field/districts/{districtId}/{doc=**} {
      allow read, write: if hasDistrict(districtId);
    }

    // -------- Medical Records --------
    match /medicalRecords/{recordId} {
      allow read: if hasDistrict(resource.data.districtId);
      allow write: if false; // All writes via Admin SDK server actions
    }

    // -------- Project Records --------
    match /projectRecords/{recordId} {
      allow read: if isActiveUser();
      allow write: if false;
    }

    // -------- Requests (Receiving workflow) --------
    match /requests/{requestId} {
      allow read: if hasDistrict(resource.data.districtId);
      allow write: if false; // All writes via Admin SDK server actions
    }

    // -------- Tasks (Kanban) --------
    match /tasks/{taskId} {
      allow read: if isActiveUser();
      allow write: if false; // All writes via Admin SDK server actions
    }

    // -------- SocMed Campaigns --------
    match /socmedCampaigns/{campaignId} {
      // SocMed staff (Admin/Manager/Validator) see every campaign, including pending and rejected.
      allow read: if isSocmedStaff();
      // Checker needs to see active campaigns to contextualize submissions to review.
      allow read: if isSocmedChecker() && resource.data.status in ['active', 'completed'];
      // Other active users (including Agents) see published states or campaigns they themselves submitted.
      allow read: if isActiveUser() && (
        resource.data.status in ['validated', 'active', 'completed']
        || resource.data.submitted_by == request.auth.uid
      );
      // All writes via Admin SDK server actions
      allow write: if false;
    }

    // -------- SocMed Submissions --------
    match /socmedSubmissions/{submissionId} {
      // Staff and Checkers can read every submission for validation, checking, and reporting.
      allow read: if isSocmedStaff() || isSocmedChecker();
      // Agents can read only their own submissions.
      allow read: if isActiveUser() && resource.data.agent_id == request.auth.uid;
      // All writes via Admin SDK server actions
      allow write: if false;
    }

    // -------- SocMed Groups --------
    match /socmedGroups/{groupId} {
      // Anyone with a SocMed role can read groups (staff need them for rollout config;
      // agents may want to know which group they belong to).
      allow read: if hasSocmedRole();
      // All writes via Admin SDK server actions
      allow write: if false;
    }

    // -------- Audit logs (write via Admin SDK; OIC+ can read for auditing) --------
    match /auditLogs/{logId} {
      allow read: if isAdminOrOIC();
      allow write: if false;
    }

    // -------- Default deny --------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
